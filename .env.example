# ─────────────────────────────────────────────
#  Google OAuth (NextAuth.js — user-facing login)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Production domain — also used by NextAuth v5 as AUTH_URL
AUTH_URL=https://francine.lantix.ca
NEXTAUTH_URL=https://francine.lantix.ca

# Required when running behind a reverse proxy (nginx, Traefik, Caddy, etc.)
# Tells NextAuth to trust the X-Forwarded-Host header
AUTH_TRUST_HOST=true

# ─────────────────────────────────────────────
#  Google Service Account (server-side API calls)
#  Base64-encode the JSON key: base64 -i key.json
# ─────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# ─────────────────────────────────────────────
#  Google Workspace resource IDs
# ─────────────────────────────────────────────

# Google Sheets — create one spreadsheet; paste its ID from the URL
GOOGLE_SHEET_ID=

# Google Calendar — the calendar used for appointments
GOOGLE_CALENDAR_ID=primary

# Google Drive — folder where invoice PDFs are stored
GOOGLE_DRIVE_FOLDER_ID=

# ─────────────────────────────────────────────
#  App settings
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Francine CRM"
NEXT_PUBLIC_APP_URL=https://francine.lantix.ca

# Interpreter / business name shown on PDF invoices and email footers
# (distinct from the app name above)
NEXT_PUBLIC_BUSINESS_NAME="Francine Gillis"

# Default tax rate applied to invoices (percentage, e.g. 13 for 13%)
TAX_RATE_PERCENT=0

# ─────────────────────────────────────────────
#  Email sending — choose one provider
# ─────────────────────────────────────────────

# Option A: Resend (recommended — resend.com, free tier 3k/month)
# If set, Resend is used regardless of other email settings.
RESEND_API_KEY=

# Option B: Gmail OAuth2 — connect via Settings page in the app
# GMAIL_REFRESH_TOKEN is set automatically by the in-app Connect flow,
# or you can paste a refresh token here directly.
GMAIL_REFRESH_TOKEN=

# The "From" address shown on outgoing emails.
# For Resend: must match a verified sender domain in your Resend account.
# For Gmail OAuth2: must be the Gmail address you connected.
EMAIL_FROM_ADDRESS=you@yourdomain.com
# Legacy alias — still accepted if EMAIL_FROM_ADDRESS is not set
GMAIL_FROM_ADDRESS=

# ─────────────────────────────────────────────
#  Access control
# ─────────────────────────────────────────────

# Comma-separated list of Google email addresses allowed to log in.
# If left blank, any Google account can authenticate (not recommended for production).
ALLOWED_EMAILS=you@gmail.com

# ─────────────────────────────────────────────
#  Calendar
# ─────────────────────────────────────────────

# IANA timezone for calendar events (e.g. America/Toronto, America/Vancouver)
CALENDAR_TIMEZONE=America/Toronto

# ─────────────────────────────────────────────
#  Cron / scheduled tasks
# ─────────────────────────────────────────────

# Random secret used to authenticate the payment-reminders cron endpoint.
# Set this in your GitHub repository secrets (Settings → Secrets → Actions)
# as CRON_SECRET, and set APP_URL to your production URL (e.g. https://francine.example.com).
# The .github/workflows/reminders.yml workflow calls GET /api/cron/payment-reminders daily.
CRON_SECRET=
